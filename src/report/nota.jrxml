<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="null" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="9cac4f2c-79f7-4c84-bfc7-8799e3c16c18">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="7"/>
	<parameter name="idnota" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     isi.`idnota` AS isi_idnota,
     isi.`kd_brg` AS isi_kd_brg,
     isi.`hb` AS isi_hb,
     isi.`hj` AS isi_hj,
     isi.`qty` AS isi_qty,
     barang.`kd_barang` AS barang_kd_barang,
     barang.`nm_barang` AS barang_nm_barang,
     barang.`jenis_barang` AS barang_jenis_barang,
     barang.`hg_jual` AS barang_hg_jual,
     barang.`hg_beli` AS barang_hg_beli,
     kasir.`id_kasir` AS kasir_id_kasir,
     kasir.`nm_kasir` AS kasir_nm_kasir,
     kasir.`jenis_kelamin` AS kasir_jenis_kelamin,
     kasir.`no_telepon` AS kasir_no_telepon,
     kasir.`agama` AS kasir_agama,
     kasir.`alamat` AS kasir_alamat,
     kasir.`password` AS kasir_password,
     nota.`idnota` AS nota_idnota,
     nota.`tglnota` AS nota_tglnota,
     nota.`id_pelanggan` AS nota_id_pelanggan,
     nota.`id_kasir` AS nota_id_kasir,
     pelanggan.`id` AS pelanggan_id,
     pelanggan.`nmplg` AS pelanggan_nmplg,
     pelanggan.`jenis` AS pelanggan_jenis,
     pelanggan.`telepon` AS pelanggan_telepon,
     pelanggan.`alamat` AS pelanggan_alamat
FROM
     `barang` barang INNER JOIN `isi` isi ON barang.`kd_barang` = isi.`kd_brg`
     INNER JOIN `nota` nota ON isi.`idnota` = nota.`idnota`
     INNER JOIN `kasir` kasir ON nota.`id_kasir` = kasir.`id_kasir`
     INNER JOIN `pelanggan` pelanggan ON nota.`id_pelanggan` = pelanggan.`id` WHERE nota.idnota=$P{idnota}]]>
	</queryString>
	<field name="isi_idnota" class="java.lang.String"/>
	<field name="isi_kd_brg" class="java.lang.String"/>
	<field name="isi_hb" class="java.lang.Integer"/>
	<field name="isi_hj" class="java.lang.Integer"/>
	<field name="isi_qty" class="java.lang.Integer"/>
	<field name="barang_kd_barang" class="java.lang.String"/>
	<field name="barang_nm_barang" class="java.lang.String"/>
	<field name="barang_jenis_barang" class="java.lang.String"/>
	<field name="barang_hg_jual" class="java.lang.Integer"/>
	<field name="barang_hg_beli" class="java.lang.Integer"/>
	<field name="kasir_id_kasir" class="java.lang.String"/>
	<field name="kasir_nm_kasir" class="java.lang.String"/>
	<field name="kasir_jenis_kelamin" class="java.lang.String"/>
	<field name="kasir_no_telepon" class="java.lang.String"/>
	<field name="kasir_agama" class="java.lang.String"/>
	<field name="kasir_alamat" class="java.lang.String"/>
	<field name="kasir_password" class="java.lang.String"/>
	<field name="nota_idnota" class="java.lang.String"/>
	<field name="nota_tglnota" class="java.sql.Date"/>
	<field name="nota_id_pelanggan" class="java.lang.String"/>
	<field name="nota_id_kasir" class="java.lang.String"/>
	<field name="pelanggan_id" class="java.lang.String"/>
	<field name="pelanggan_nmplg" class="java.lang.String"/>
	<field name="pelanggan_jenis" class="java.lang.String"/>
	<field name="pelanggan_telepon" class="java.lang.String"/>
	<field name="pelanggan_alamat" class="java.lang.String"/>
	<variable name="subtotal" class="java.lang.Integer">
		<variableExpression><![CDATA[$F{isi_qty}*$F{isi_hj}]]></variableExpression>
	</variable>
	<variable name="totalbelanja" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$V{subtotal}]]></variableExpression>
	</variable>
